# ═══════════════════════════════════════════════════════════════════════════════
#  Crypto News Bot — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (local development — file will be created automatically)
DATABASE_URL="file:./dev.db"

# For Supabase (production), replace with your Postgres URL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ─── AI — Anthropic Claude ───────────────────────────────────────────────────
# Required for article rewriting.
# Get your key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (defaults to claude-sonnet-4-6 if not set)
CLAUDE_MODEL=claude-sonnet-4-6

# ─── AI — OpenAI (Image Generation) ─────────────────────────────────────────
# Optional — if not set, image generation is skipped gracefully.
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── X (Twitter) API ─────────────────────────────────────────────────────────
# Required for auto-posting to X.
# Create a project at: https://developer.twitter.com/en/portal/dashboard
# Requires OAuth 1.0a User Auth with Read + Write permissions.
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_token_secret

# ─── Facebook Page API ───────────────────────────────────────────────────────
# Required for auto-posting to your Facebook Page.
# Get a Page Access Token from: https://developers.facebook.com/tools/explorer
# Token needs: pages_manage_posts, pages_read_engagement
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token

# ─── LinkedIn API ────────────────────────────────────────────────────────────
# Required for auto-posting to LinkedIn.
# Create an app at: https://www.linkedin.com/developers/apps
# Scopes needed: w_member_social, r_liteprofile
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
# Your LinkedIn person URN — find it with: GET https://api.linkedin.com/v2/me
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# ─── RSS Feed ────────────────────────────────────────────────────────────────
# Cointelegraph RSS URL (you can change to another crypto news feed)
RSS_FEED_URL=https://cointelegraph.com/rss

# ─── Scheduler ───────────────────────────────────────────────────────────────
# Cron expression for the daily automation schedule.
# Default: 09:00 every morning.
# Format: minute hour day month weekday
CRON_SCHEDULE=0 9 * * *

# Timezone for the cron scheduler.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
CRON_TIMEZONE=Europe/London

# ─── Auto-Publishing ─────────────────────────────────────────────────────────
# Set to "true" to automatically publish posts after generation (no manual approval step).
# Set to "false" (default) to require dashboard approval before publishing.
AUTO_PUBLISH=false

# ─── Next.js ─────────────────────────────────────────────────────────────────
# Only needed for deployment — leave blank for local dev.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_string_here
