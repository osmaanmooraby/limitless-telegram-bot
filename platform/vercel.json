{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "0,15,30,45 * * * *"
    }
  ],
  "functions": {
    "src/app/api/scanner/run/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/scan/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/market/ohlcv/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/market/tickers/route.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "PRISMA_GENERATE_DATAPROXY": "false"
  }
}
